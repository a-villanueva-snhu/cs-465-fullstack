<!DOCTYPE html>
<!-- Website template by freewebsitetemplates.com -->
<html>
<head>
	<meta charset="UTF-8">
	<title>Contact - Travlr Getaways Website Template</title>
	<link rel="stylesheet" href="css/style.css" type="text/css">
</head>
<body>
	<div id="background">
		<div id="page">
			{{> header }}
			<div id="contents">
				<div class="box">
					<div>
						<div class="body">
							<h1>Contact</h1>
							<h2>Get in Touch</h2>
							<p>
								We'd love to hear from you! Whether you have questions about our travel packages, need help with your booking, or just want to share your experience, our team is here to help.
							</p>
							<form action="/contact" method="post">
								<div class="form-group">
									<label for="name">Name:</label>
									<input type="text" id="name" name="name" required>
								</div>
								<div class="form-group">
									<label for="email">Email:</label>
									<input type="email" id="email" name="email" required>
								</div>
								<div class="form-group">
									<label for="message">Message:</label>
									<textarea id="message" name="message" rows="5" required></textarea>
								</div>
								<button type="submit">Send Message</button>
							</form>
							<h2>Contact Information</h2>
							<p>
								<strong>Address:</strong> 123 Beach Road, Paradise Island<br>
								<strong>Phone:</strong> (555) 123-4567<br>
								<strong>Email:</strong> info@travlrgetaways.com
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
		{{> footer }}
			<p>
				© 2023 by Travlr Getaways. All Rights Reserved
			</p>
		</div>
	</div>
</body>
</html>