<!DOCTYPE html>
<!-- Website template by freewebsitetemplates.com -->
<html>
<head>
	<meta charset="UTF-8">
	<title>Foods - Travlr Getaways Website Template</title>
	<link rel="stylesheet" href="css/style.css" type="text/css">
</head>
<body>
	<div id="background">
		<div id="page">
			{{> header }}
			<div id="contents">
				<div class="box">
					<div>
						<div class="body">
							<h1>Meals</h1>
							<ul id="foods">
								{{#each meals}}
                                <li>
                                    <a href = "/meals"><img src="images/{{this.image}}" alt="Img"></a>
                                    <h2><a href = "/meals">{{this.name}}</a></h2>
                                    <p>{{this.description}}</p>
                                </li>
                                {{/each}}
							</ul>
						</div>
					</div>
				</div>
			</div>
		    {{> footer }}
			<p>
				© 2023 by Travlr Getaways. All Rights Reserved
			</p>
		</div>
	</div>
</body>
</html>